# 팔자 리포트 — 웹 환경변수 (.env.local 로 복사)
# 전부 비워도 개발 구동됨(stub·인메모리·mock). 키 넣으면 해당 기능이 실연동으로 전환.

# LLM (없으면 안전 stub)
ANTHROPIC_API_KEY=

# 영속화 (둘 다 있으면 Supabase, 없으면 인메모리). 스키마: supabase/schema.sql
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 결제 (있으면 토스 실승인, 없으면 mock). 클라이언트 위젯은 별도 CLIENT KEY 필요
TOSS_SECRET_KEY=

# 데일리 푸시 dispatch 보호 (supabase/cron.sql이 이 값으로 호출)
CRON_SECRET=
